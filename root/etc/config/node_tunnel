config global 'global'
	option enabled '0'
	option log_level 'warn'

config node 'node'
	option enabled '0'
	option core 'sing-box'
	option protocol 'socks5'
	option listen_addr '0.0.0.0'
	option listen_port '1080'
	option http_port '1081'
	option username ''
	option password ''
	option config_path '/var/etc/node_tunnel_node.json'

config argo 'argo'
	option enabled '0'
	option mode 'quick'
	option token ''
	option tunnel_name ''
	option target_type 'node'
	option target_addr '127.0.0.1'
	option target_port '1080'
	option target_proto 'socks5'
	option http_hostname ''
	option url_file '/var/run/node_tunnel_argo.url'
	option log_file '/var/log/node_tunnel_argo.log'

config frp 'frp'
	option enabled '0'
	option server_addr ''
	option server_port '7000'
	option auth_token ''
	option tunnel_type 'tcp'
	option local_addr '127.0.0.1'
	option local_port '1080'
	option remote_port '6000'
	option subdomain ''
	option custom_domain ''
	option config_path '/var/etc/node_tunnel_frpc.toml'
